Redeem_Integration_Concrete_Test
├── given null
│  └── it should revert
└── given not null
   ├── given active
   │  ├── when sync not change status
   │  │  └── it should revert
   │  └── when sync changes status
   │     ├── it should sync price from oracle
   │     ├── it should burn all shares
   │     ├── it should transfer tokens to depositor
   │     └── it should emit {SyncPriceFromOracle} and {Redeem} events
   ├── given expired
   │  ├── it should not sync price from oracle
   │  ├── it should burn all shares
   │  ├── it should transfer tokens to depositor
   │  └── it should emit a {Redeem} event
   └── given settled
      ├── when shares zero
      │  └── it should revert
      └── when shares not zero
         ├── given no adapter
         │  ├── when fee not exceed min fee
         │  │  └── it should revert
         │  └── when fee exceeds min fee
         │     ├── it should not sync price from oracle
         │     ├── it should transfer fee to comptroller
         │     ├── it should burn all shares
         │     ├── it should transfer tokens to depositor
         │     └── it should emit a {Redeem} event
         └── given adapter
            ├── given staked in adapter
            │  ├── it should trigger unstake via adapter
            │  ├── it should set isStakedInAdapter to false
            │  ├── it should burn all shares
            │  ├── it should yield fee to the comptroller
            │  ├── it should transfer tokens to depositor
            │  └── it should emit a {Redeem} event
            └── given not staked in adapter
               ├── it should burn all shares
               ├── it should transfer yield fee to the comptroller
               ├── it should transfer tokens to depositor
               └── it should emit a {Redeem} event

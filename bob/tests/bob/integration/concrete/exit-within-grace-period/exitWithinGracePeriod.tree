ExitWithinGracePeriod_Integration_Concrete_Test
├── given null
│  └── it should revert
└── given not null
   ├── given settled
   │  └── it should revert
   ├── given expired
   │  └── it should revert
   └── given active
      ├── when shares zero
      │  └── it should revert
      └── when shares not zero
         ├── given first deposit time zero
         │  └── it should revert
         └── given first deposit time not zero
            ├── when grace end time not in future
            │  └── it should revert
            └── when grace end time in future
               ├── given no adapter
               │  ├── it should burn all shares
               │  ├── it should clear the first deposit time
               │  ├── it should return the deposit amount
               │  └── it should emit an {ExitWithinGracePeriod} event
               └── given adapter
                  ├── it should burn all shares
                  ├── it should clear the first deposit time
                  ├── it should unstake via the adapter
                  ├── it should set user wstETH balance to 0
                  ├── it should reduce adapter wstETH balance
                  ├── it should return the deposit amount
                  └── it should emit an {ExitWithinGracePeriod} and {UnstakeForUserWithinGracePeriod} events
